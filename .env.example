# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Configuration
# Supported: mysql, mongodb
DB_TYPE=mongodb
DB_HOST=localhost
DB_PORT=27017
DB_NAME=openlogtool
DB_USER=
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Sync Configuration
SYNC_STRATEGY=server-wins  # Options: server-wins, client-wins, manual
