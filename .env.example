# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Configuration
# Supported: memory, mysql, mongodb
DB_TYPE=memory
DB_HOST=localhost
DB_PORT=3306
DB_NAME=openlogtool
DB_USER=
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=change-this-secret-key-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Sync Configuration
SYNC_STRATEGY=server-wins